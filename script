def export_xlsx(results: dict, df_base: pd.DataFrame, out_dir: str):
    """
    results = {
      "Temporal":         (png_path, df),
      "Autores":          (png_path, df),
      ...
    }
    """
    print("  → Exportando planilha Excel…")
    wb = Workbook()
    wb.remove(wb.active)   # remove sheet padrão

    # ── Aba Capa ──────────────────────────────────────────
    ws_cover = wb.create_sheet("Capa")
    ws_cover.sheet_view.showGridLines = False
    ws_cover.column_dimensions["A"].width = 60
    ws_cover.row_dimensions[1].height = 40

    ws_cover["A1"] = "RELATÓRIO BIBLIOMÉTRICO — PORTAL CAPES"
    ws_cover["A1"].font      = Font(bold=True, size=18, name="Arial", color="1F4E79")
    ws_cover["A1"].alignment = CENTER

    info = [
        ("Total de registros", len(df_base)),
        ("Período", f'{df_base["year_int"].min()} – {df_base["year_int"].max()}'),
        ("Data da análise", pd.Timestamp.today().strftime("%d/%m/%Y")),
        ("Fonte", "Portal CAPES + OpenAlex"),
    ]
    for i, (k,v) in enumerate(info, start=3):
        ws_cover[f"A{i}"] = f"{k}: {v}"
        ws_cover[f"A{i}"].font      = Font(size=12, name="Arial", color="2E75B6")
        ws_cover[f"A{i}"].alignment = LEFT
        ws_cover.row_dimensions[i].height = 20

    # Índice de abas
    ws_cover["A9"] = "CONTEÚDO DA PLANILHA"
    ws_cover["A9"].font = Font(bold=True, size=13, name="Arial", color="1F4E79")
    ws_cover.row_dimensions[9].height = 20
    abas = list(results.keys())
    for i, a in enumerate(abas, start=10):
        ws_cover[f"A{i}"] = f"  • {a}"
        ws_cover[f"A{i}"].font      = Font(size=11, name="Arial")
        ws_cover[f"A{i}"].alignment = LEFT

    # ── Aba Base de Dados ──────────────────────────────────
    ws_data = wb.create_sheet("Base de Dados")
    cols_show = [c for c in df_base.columns
                 if c not in ("ENTRYTYPE","ID") and not c.startswith("doi")]
    write_df_to_sheet(ws_data, df_base[cols_show].fillna(""), "Registros Bibliográficos")

    # ── Abas de análise ───────────────────────────────────
    for sheet_name, (png_path, df_res) in results.items():
        ws = wb.create_sheet(sheet_name[:31])   # Excel limita a 31 chars
        ws.sheet_view.showGridLines = False

        if df_res is not None and not df_res.empty:
            write_df_to_sheet(ws, df_res.fillna("").astype(str), sheet_name)

        # Inserir imagem PNG abaixo da tabela
        if png_path and os.path.exists(png_path):
            img_row = ws.max_row + 2
            try:
                img = XLImage(png_path)
                img.width  = min(img.width,  900)
                img.height = min(img.height, 600)
                ws.add_image(img, f"A{img_row}")
                ws.row_dimensions[img_row].height = img.height * 0.75
            except Exception as e:
                ws[f"A{img_row}"] = f"(imagem não inserida: {e})"

    # ── Aba LDA extra (documentos) ─────────────────────────
    if "LDA – Documentos" in results:
        pass   # já incluído em results

    xlsx_path = os.path.join(out_dir, "relatorio_bibliometrico.xlsx")
    wb.save(xlsx_path)
    print(f"  ✓ Planilha salva: {xlsx_path}")
    return xlsx_path


