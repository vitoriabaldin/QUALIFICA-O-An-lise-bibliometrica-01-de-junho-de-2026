# 2. ENRIQUECIMENTO VIA OPENALEX
# ══════════════════════════════════════════════════════════
def _openalex_fetch(doi: str, email: str):
    doi_clean = doi.strip().lower()
    if not doi_clean:
        return None
    url = f"https://api.openalex.org/works/doi:{doi_clean}"
    try:
        r = requests.get(url, params={"mailto": email}, timeout=12)
        if r.status_code == 200:
            return r.json()
    except Exception:
        pass
    return None


def enrich_with_openalex(df: pd.DataFrame, email: str) -> pd.DataFrame:
    """
    Para cada DOI consulta a API OpenAlex e extrai:
      - institution_name, institution_country, country_code, ror
    Aguarda 0.2 s entre requisições (polite pool).
    """
    print("  → Enriquecendo via OpenAlex (pode demorar alguns minutos)…")
    inst_names, inst_countries, country_codes = [], [], []

    for _, row in tqdm(df.iterrows(), total=len(df), desc="  OpenAlex"):
        data = _openalex_fetch(row["doi"], email)
        if data is None:
            inst_names.append("")
            inst_countries.append("")
            country_codes.append("")
            time.sleep(0.2)
            continue

        auths = data.get("authorships", [])
        insts, ctries, codes = [], [], []
        for auth in auths:
            for inst in auth.get("institutions", []):
                n = inst.get("display_name", "")
                c = inst.get("country_code", "")
                if n:
                    insts.append(n)
                if c:
                    codes.append(c)
                    # reverse lookup pycountry for full name
                    try:
                        import pycountry
                        country_obj = pycountry.countries.get(alpha_2=c)
                        if country_obj:
                            ctries.append(country_obj.name)
                        else:
                            ctries.append(c)
                    except Exception:
                        ctries.append(c)

        inst_names.append("; ".join(dict.fromkeys(insts)))
        inst_countries.append("; ".join(dict.fromkeys(ctries)))
        country_codes.append("; ".join(dict.fromkeys(codes)))
        time.sleep(0.2)

    df = df.copy()
    df["openalex_institution"] = inst_names
    df["openalex_country"]     = inst_countries
    df["openalex_country_code"] = country_codes
    print("  ✓ Enriquecimento concluído\n")
    return df


