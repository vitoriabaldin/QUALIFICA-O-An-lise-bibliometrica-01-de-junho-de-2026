                         color=bar_cols[::-1])
        ax3.set(xlabel="Artigos", title="Periódicos por Qualis CAPES (Top 30)")
        ax3.bar_label(bars2, padding=3)

        # legenda de estratos
        seen = {}
        for e, c in STRATA_COLORS.items():
            if e and e not in seen and e in top30["Estrato"].values:
                seen[e] = mpatches.Patch(color=c, label=e)
