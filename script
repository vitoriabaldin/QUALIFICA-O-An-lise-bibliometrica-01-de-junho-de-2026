def find_bib_files(pattern, max_n, base_dir="."):
    found = []
    for n in range(1, max_n + 1):
        p = os.path.join(base_dir, pattern.replace("{n}", str(n)))
        if os.path.exists(p):
            found.append(p)
    if not found:
        found = glob.glob(os.path.join(base_dir, "*.bib"))
    return found


def load_bib_files(paths):
    parser = BibTexParser(common_strings=True)
    parser.customization = convert_to_unicode
    all_entries = []
    for path in paths:
        try:
            with open(path, encoding="utf-8", errors="replace") as f:
                db = bibtexparser.load(f, parser=parser)
            all_entries.extend(db.entries)
            print(f"  ✓ {os.path.basename(path)} → {len(db.entries)} registros")
        except Exception as exc:
            print(f"  ✗ Erro em {os.path.basename(path)}: {exc}")

    if not all_entries:
        sys.exit("Nenhuma entrada encontrada. Verifique os arquivos .bib.")

    df = pd.DataFrame(all_entries)
    for col in ["author","title","journal","year","keywords",
                "abstract","doi","affiliation","country","volume","number","pages"]:
        if col not in df.columns:
            df[col] = ""
        df[col] = df[col].fillna("").astype(str).str.strip()

    before = len(df)
    df["doi_clean"] = df["doi"].str.lower().str.strip()
    df = df[~((df["doi_clean"] != "") & df["doi_clean"].duplicated(keep="first"))]
    df = df.drop(columns=["doi_clean"])
    print(f"\n  Total: {before} → deduplicado: {len(df)} registros\n")

    df["year_int"] = pd.to_numeric(df["year"], errors="coerce")
    df = df[df["year_int"].notna()].copy()
    df["year_int"] = df["year_int"].astype(int)
    return df.reset_index(drop=True)


