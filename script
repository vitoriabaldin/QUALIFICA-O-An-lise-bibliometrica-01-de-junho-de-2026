# ── 6. Rede de coautoria ──────────────────────────────────
def plot_coauthorship(df, out, min_deg=1):
    G = nx.Graph()
    for _, row in df.iterrows():
        authors = parse_authors(row["author"])
        for a in authors: G.add_node(a)
        for a1, a2 in combinations(authors, 2):
            if G.has_edge(a1, a2): G[a1][a2]["weight"] += 1
            else: G.add_edge(a1, a2, weight=1)

    keep = [n for n, d in G.degree() if d >= min_deg]
    G2 = G.subgraph(keep).copy() if keep else G

    fig, ax = plt.subplots(figsize=(14, 12))
    pos = nx.spring_layout(G2, k=1.3, seed=42)
    degs = dict(G2.degree())
    nx.draw_networkx_edges(G2, pos, alpha=0.3, edge_color="#888", ax=ax)
    nx.draw_networkx_nodes(G2, pos,
        node_size=[200 + degs[n]*180 for n in G2.nodes()],
        node_color=list(degs.values()), cmap=plt.cm.YlOrRd, alpha=0.85, ax=ax)
    nx.draw_networkx_labels(G2, pos, font_size=7, ax=ax)
    ax.set_title("Rede de Coautoria"); ax.axis("off")
    plt.tight_layout()
    path = savefig(os.path.join(out, "06_rede_coautoria.png"))
    deg_df = pd.DataFrame(sorted(degs.items(), key=lambda x:x[1], reverse=True),
                          columns=["Autor","Grau"])
    return path, deg_df

# ── 7. Rede de cocitação ──────────────────────────────────
def plot_cocitation(df, out):
    G = nx.Graph()
    titles = df["title"].tolist()
    auth_sets = [set(parse_authors(a)) for a in df["author"]]
    for i in range(len(df)): G.add_node(i, label=titles[i][:55])
    for i, j in combinations(range(len(df)), 2):
        shared = auth_sets[i] & auth_sets[j]
        if shared: G.add_edge(i, j, weight=len(shared))

    fig, ax = plt.subplots(figsize=(14, 12))
    pos = nx.spring_layout(G, k=1.5, seed=0)
    labels = nx.get_node_attributes(G, "label")
    nx.draw_networkx_edges(G, pos, alpha=0.25, edge_color="#AAA", ax=ax)
    nx.draw_networkx_nodes(G, pos, node_size=400, node_color="#2E86AB", alpha=0.85, ax=ax)
    nx.draw_networkx_labels(G, pos, labels=labels, font_size=6, ax=ax)
    ax.set_title("Rede de Cocitação (autores compartilhados)"); ax.axis("off")
    plt.tight_layout()
    path = savefig(os.path.join(out, "07_rede_cocitacao.png"))
    rows = [{"Artigo_i": titles[u], "Artigo_j": titles[v], "Peso": d["weight"]}
            for u,v,d in G.edges(data=True)]
    return path, pd.DataFrame(rows)

# ── 8. Acoplamento bibliográfico ──────────────────────────
def plot_coupling(df, out):
    jkw: dict[str,set] = defaultdict(set)
    for _, row in df.iterrows():
        j = row["journal"] or "Sem periódico"
        for kw in parse_keywords(row["keywords"]): jkw[j].add(kw)
    journals = list(jkw)
    G = nx.Graph()
    for j in journals: G.add_node(j)
    for j1, j2 in combinations(journals, 2):
        sh = jkw[j1] & jkw[j2]
        if sh: G.add_edge(j1, j2, weight=len(sh))

    if G.number_of_edges() == 0:
        return None, pd.DataFrame({"Nota":["Keywords ausentes — acoplamento não calculado."]})

    fig, ax = plt.subplots(figsize=(14, 10))
    pos = nx.spring_layout(G, k=2, seed=7)
    ws = [G[u][v]["weight"] for u,v in G.edges()]
    nx.draw_networkx_edges(G, pos, width=[w*0.5 for w in ws],
                           alpha=0.5, edge_color="#FF6B6B", ax=ax)
    nx.draw_networkx_nodes(G, pos, node_size=800, node_color="#4ECDC4", ax=ax)
    nx.draw_networkx_labels(G, pos, font_size=7, ax=ax)
    ax.set_title("Acoplamento Bibliográfico entre Periódicos"); ax.axis("off")
    plt.tight_layout()
    path = savefig(os.path.join(out, "08_acoplamento.png"))
    rows = [{"Periódico_i":u,"Periódico_j":v,"Keywords_compartilhadas":d["weight"]}
            for u,v,d in G.edges(data=True)]
    return path, pd.DataFrame(rows)

