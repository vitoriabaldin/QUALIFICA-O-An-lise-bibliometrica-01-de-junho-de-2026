import html as _html

def _get(url, params=None, timeout=12):
    """GET com retry simples."""
    for attempt in range(2):
        try:
            r = requests.get(url, params=params, timeout=timeout)
            if r.status_code == 200:
                return r
        except Exception:
            time.sleep(1)
    return None

def _clean_abstract(text: str) -> str:
    """Remove tags HTML e entidades."""
    if not text:
        return ""
    text = _html.unescape(text)
    text = re.sub(r"<[^>]+>", " ", text)
    return re.sub(r"\s+", " ", text).strip()

# ── SciELO ───────────────────────────────────────────────
def _scielo_fetch(doi: str, title: str) -> dict:
    """
    Tenta pelo DOI primeiro; se falhar, busca por título.
    Retorna dict com: abstract, keywords, affiliation, country_code, doc_type
    """
    result = {}
    r = None

    # 1) busca por DOI
    if doi:
        doi_clean = doi.strip()
        for prefix in ("https://doi.org/", "http://doi.org/",
                       "https://dx.doi.org/", "http://dx.doi.org/"):
            doi_clean = doi_clean.replace(prefix, "")
        r = _get("https://articlemeta.scielo.org/api/v1/article/",
                 params={"doi": doi_clean, "format": "json"})
        if r is None:
            r = _get("https://articlemeta.scielo.org/api/v1/article/",
                     params={"code": doi_clean, "format": "json"})

    # 2) busca por título se DOI falhou
    if r is None and title:
        r2 = _get("https://search.scielo.org/api/v1/search/",
                  params={"q": f'ti:"{title[:80]}"', "count": 1, "format": "json"})
        if r2:
            try:
                hits = r2.json().get("hits", {}).get("hits", [])
                if hits:
                    pid = hits[0].get("_id", "")
                    if pid:
                        r = _get("https://articlemeta.scielo.org/api/v1/article/",
                                 params={"code": pid, "format": "json"})
            except Exception:
                pass

    if r is None:
        return result

    try:
        data = r.json()
    except Exception:
        return result

    # data pode ser None, lista ou dict dependendo do endpoint
    if not isinstance(data, dict):
        return result

    # article pode ser None em algumas respostas
    article = data.get("article") or {}
    title_meta = data.get("title") or {}

    # abstract — pega pt, es ou en
    abst_dict = article.get("v83") or []
    if isinstance(abst_dict, list):
        for item in abst_dict:
            if not isinstance(item, dict):
                continue
            lang = item.get("l", "")
            text = item.get("_", "")
            if text:
                result.setdefault("abstract", _clean_abstract(text))
                if lang in ("pt", "es"):
                    result["abstract"] = _clean_abstract(text)
                    break

    # keywords
    kw_dict = article.get("v85") or []
    if isinstance(kw_dict, list):
        kws = [item.get("_", "") for item in kw_dict
               if isinstance(item, dict) and item.get("_")]
        if kws:
            result["keywords"] = "; ".join(kws)

    # afiliação
    aff_list = article.get("v240") or []
    if isinstance(aff_list, list):
        affs = [item.get("_", "") for item in aff_list
                if isinstance(item, dict) and item.get("_")]
        if affs:
            result["affiliation"] = "; ".join(affs)

    # país via journal country
    try:
        v310 = title_meta.get("v310") or [{}]
        country = v310[0].get("_", "") if isinstance(v310, list) else ""
        if country:
            result["country_code"] = country.upper()[:2]
    except Exception:
        pass

    # tipo de documento
    try:
        v71 = article.get("v71") or [{}]
        doc_type = v71[0].get("_", "") if isinstance(v71, list) else ""
        if doc_type:
            result["doc_type"] = doc_type
    except Exception:
        pass

    return result

# ── Crossref ─────────────────────────────────────────────
def _crossref_fetch(doi: str, email: str) -> dict:
    if not doi:
        return {}
    result = {}
    url = f"https://api.crossref.org/works/{requests.utils.quote(doi.strip(), safe='')}"
    r = _get(url, params={"mailto": email})
    if r is None:
        return result
    try:
        msg = r.json().get("message", {})
    except Exception:
        return result

    # abstract
    abst = msg.get("abstract", "")
    if abst:
        result["abstract"] = _clean_abstract(abst)

    # tipo de documento
    result["doc_type"] = msg.get("type", "")

    # afiliação e país
    insts, codes = [], []
    for auth in msg.get("author", []):
        for aff in auth.get("affiliation", []):
            name = aff.get("name", "")
            if name:
                insts.append(name)
    if insts:
        result["affiliation"] = "; ".join(dict.fromkeys(insts))

    # referências (lista de DOIs citados)
    refs = []
    for ref in msg.get("reference", []):
        rdoi = ref.get("DOI", "")
        if rdoi:
            refs.append(rdoi)
    if refs:
        result["references"] = refs

    return result

# ── Semantic Scholar ──────────────────────────────────────
def _s2_fetch(doi: str, title: str, api_key: str = "") -> dict:
    result = {}
    fields  = "title,abstract,authors,year,externalIds,tldr,topics"
    r = None

    # por DOI
    if doi:
        r = _get(f"https://api.semanticscholar.org/graph/v1/paper/DOI:{doi.strip()}",
                 params={"fields": fields})
        if r is None and api_key:
            time.sleep(1)

    # por título se DOI falhou
    if (not doi or r is None) and title:
        r = _get("https://api.semanticscholar.org/graph/v1/paper/search",
                 params={"query": title[:120], "fields": fields, "limit": 1})
        if r:
            try:
                items = r.json().get("data", [])
                r = None
                if items:
                    pid = items[0].get("paperId", "")
                    r = _get(f"https://api.semanticscholar.org/graph/v1/paper/{pid}",
                             params={"fields": fields}) if pid else None
            except Exception:
                r = None

    if r is None:
        return result

    try:
        data = r.json()
    except Exception:
        return result

    abst = data.get("abstract") or ""
    if abst:
        result["abstract"] = _clean_abstract(abst)

    # tldr como fallback de abstract curto
    tldr = (data.get("tldr") or {}).get("text", "")
    if tldr and not result.get("abstract"):
        result["abstract"] = tldr

    # tópicos
    topics = [t.get("topic", "") for t in data.get("topics", []) if t.get("topic")]
    if topics:
        result["keywords"] = "; ".join(topics[:10])

    return result

# ── OpenAlex ──────────────────────────────────────────────
def _openalex_fetch(doi: str, title: str, email: str) -> dict:
    result = {}

    # por DOI
    r = None
    if doi:
        r = _get(f"https://api.openalex.org/works/doi:{doi.strip()}",
                 params={"mailto": email})

    # por título
    if r is None and title:
        r = _get("https://api.openalex.org/works",
                 params={"filter": f'title.search:{title[:100]}',
                         "per-page": 1, "mailto": email})
        if r:
            try:
                items = r.json().get("results", [])
                r = None
                if items:
                    wid = items[0].get("id", "").replace("https://openalex.org/", "")
                    r = _get(f"https://api.openalex.org/works/{wid}",
                             params={"mailto": email}) if wid else None
            except Exception:
                r = None

    if r is None:
        return result

    try:
        data = r.json()
    except Exception:
        return result

    # abstract (OpenAlex armazena como inverted index)
    inv = data.get("abstract_inverted_index") or {}
    if inv:
        try:
            words = {pos: w for w, positions in inv.items() for pos in positions}
            result["abstract"] = " ".join(words[i] for i in sorted(words))
        except Exception:
            pass

    # keywords / concepts
    concepts = [c.get("display_name", "") for c in data.get("concepts", [])
                if c.get("score", 0) > 0.3]
    if concepts:
        result["keywords"] = "; ".join(concepts[:10])

    # instituição e país
    insts, codes = [], []
    for auth in data.get("authorships", []):
        for inst in auth.get("institutions", []):
            n = inst.get("display_name", "")
            c = inst.get("country_code", "")
            if n: insts.append(n)
            if c: codes.append(c)
    if insts:
        result["affiliation"] = "; ".join(dict.fromkeys(insts))
    if codes:
        result["country_code"] = "; ".join(dict.fromkeys(codes))

    # tipo
    result["doc_type"] = data.get("type", "")

    return result

# ── Unpaywall ─────────────────────────────────────────────
def _unpaywall_fetch(doi: str, email: str) -> dict:
    if not doi:
        return {}
    r = _get(f"https://api.unpaywall.org/v2/{requests.utils.quote(doi.strip(), safe='')}",
             params={"email": email})
    if r is None:
        return {}
    try:
        data = r.json()
    except Exception:
        return {}

    result = {}
    result["doc_type"]     = data.get("genre", "")
    result["is_oa"]        = str(data.get("is_oa", ""))
    result["oa_url"]       = (data.get("best_oa_location") or {}).get("url_for_pdf", "")
    result["journal_issn"] = data.get("journal_issn_l", "")
    return result

# ── CASCATA PRINCIPAL ─────────────────────────────────────
_DOC_TYPE_NOISE = {
    "book-chapter", "book", "proceedings-article",
    "review", "editorial", "letter", "erratum",
    "resenha", "editorial", "carta"
}

def enrich_cascade(df: pd.DataFrame, email: str, s2_key: str = "") -> pd.DataFrame:
    """
    Para cada registro tenta, em cascata:
      1. SciELO  (melhor para revistas brasileiras)
      2. Crossref (tipo de documento + referências)
      3. Semantic Scholar (abstract + tópicos)
      4. OpenAlex (instituição + país + conceitos)
      5. Unpaywall (OA + PDF URL)

    Campos preenchidos (nunca sobrescreve dado já existente):
      enrich_abstract, enrich_keywords, enrich_affiliation,
      enrich_country_code, enrich_doc_type, enrich_references,
      enrich_is_oa, enrich_oa_url, enrich_source (quais APIs responderam)
    """
    print("\n  Enriquecimento em cascata: SciELO → Crossref → S2 → OpenAlex → Unpaywall")
    print("  (pode demorar — ~1-2 s por registro)\n")

    cols = ["enrich_abstract","enrich_keywords","enrich_affiliation",
            "enrich_country_code","enrich_doc_type","enrich_references",
            "enrich_is_oa","enrich_oa_url","enrich_source","enrich_is_noise"]
    for c in cols:
        df[c] = ""

    for idx, row in tqdm(df.iterrows(), total=len(df), desc="  Enriquecendo"):
        doi   = str(row.get("doi",   "") or "").strip()
        title = str(row.get("title", "") or "").strip()
        merged = {}
        sources = []

        def _merge(src_dict, src_name):
            if not src_dict: return
            sources.append(src_name)
            for k, v in src_dict.items():
                if v and k not in merged:
                    merged[k] = v

        # 1. SciELO
        try:
            time.sleep(0.3)
            _merge(_scielo_fetch(doi, title), "SciELO")
        except Exception as e:
            pass  # falha silenciosa — próxima API

        # 2. Crossref
        try:
            time.sleep(0.2)
            _merge(_crossref_fetch(doi, email), "Crossref")
        except Exception:
            pass

        # 3. Semantic Scholar (só se ainda falta abstract)
        if not merged.get("abstract"):
            try:
                time.sleep(1.1)
                _merge(_s2_fetch(doi, title, s2_key), "S2")
            except Exception:
                pass

        # 4. OpenAlex (complementa instituição/país/keywords)
        if not merged.get("affiliation") or not merged.get("abstract"):
            try:
                time.sleep(0.3)
                _merge(_openalex_fetch(doi, title, email), "OpenAlex")
            except Exception:
                pass

        # 5. Unpaywall (sempre — para OA e tipo)
        if doi:
            try:
                time.sleep(0.2)
                _merge(_unpaywall_fetch(doi, email), "Unpaywall")
            except Exception:
                pass

        # Grava resultados
        df.at[idx, "enrich_abstract"]    = merged.get("abstract", "")
        df.at[idx, "enrich_keywords"]    = merged.get("keywords", "")
        df.at[idx, "enrich_affiliation"] = merged.get("affiliation", "")
        df.at[idx, "enrich_country_code"]= merged.get("country_code", "")
        df.at[idx, "enrich_doc_type"]    = merged.get("doc_type", "")
        df.at[idx, "enrich_references"]  = "; ".join(merged.get("references", []))
        df.at[idx, "enrich_is_oa"]       = merged.get("is_oa", "")
        df.at[idx, "enrich_oa_url"]      = merged.get("oa_url", "")
        df.at[idx, "enrich_source"]      = ", ".join(sources) if sources else "nenhuma"

        # Marca ruído por tipo de documento
        doc_type = merged.get("doc_type", "").lower()
        df.at[idx, "enrich_is_noise"] = "sim" if any(
            noise in doc_type for noise in _DOC_TYPE_NOISE) else "não"

    # Combina campos originais com enriquecidos (original tem prioridade)
    df["abstract_final"]  = df.apply(
        lambda r: r["abstract"]         if r.get("abstract")     else r["enrich_abstract"],  axis=1)
    df["keywords_final"]  = df.apply(
        lambda r: r["keywords"]         if r.get("keywords")     else r["enrich_keywords"],  axis=1)
    df["affiliation_final"]= df.apply(
        lambda r: r["affiliation"]      if r.get("affiliation")  else r["enrich_affiliation"],axis=1)
    df["country_final"]   = df.apply(
        lambda r: r.get("openalex_country_code","") or r["enrich_country_code"], axis=1)

    # Relatório de cobertura
    total = len(df)
    print(f"\n  📊 Cobertura após enriquecimento ({total} registros):")
    print(f"     Abstract    : {df['abstract_final'].ne('').sum():>4} / {total}")
    print(f"     Keywords    : {df['keywords_final'].ne('').sum():>4} / {total}")
    print(f"     Afiliação   : {df['affiliation_final'].ne('').sum():>4} / {total}")
    print(f"     País        : {df['country_final'].ne('').sum():>4} / {total}")
    print(f"     Referências : {df['enrich_references'].ne('').sum():>4} / {total}")
    print(f"     Prováv. ruído: {df['enrich_is_noise'].eq('sim').sum():>3} registros marcados")

    src_counts = {}
    for s in df["enrich_source"]:
        for api in s.split(", "):
            src_counts[api] = src_counts.get(api, 0) + 1
    print("     Contribuição por API:")
