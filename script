# ── 10. Coocorrência de termos ────────────────────────────
def plot_cooccurrence(df, out, top_terms=40, min_cooc=2):
    docs = []
    for _, row in df.iterrows():
        toks = tokenize(row["title"] + " " + row.get("abstract",""))
        if toks: docs.append(toks)

    freq: Counter = Counter(t for d in docs for t in d)
    vocab = {t for t,_ in freq.most_common(top_terms)}
    cooc: Counter = Counter()
    for doc in docs:
        dv = list(set(t for t in doc if t in vocab))
        for pair in combinations(dv, 2): cooc[tuple(sorted(pair))] += 1

    filtered = {k:v for k,v in cooc.items() if v >= min_cooc}
    if not filtered:
        return None, pd.DataFrame()

    G = nx.Graph()
    for (t1,t2), w in filtered.items(): G.add_edge(t1, t2, weight=w)

    fig, ax = plt.subplots(figsize=(16, 12))
    pos = nx.spring_layout(G, k=1.5, seed=42)
    degs = dict(G.degree())
    nx.draw_networkx_edges(G, pos,
        width=[G[u][v]["weight"]*0.6 for u,v in G.edges()],
        alpha=0.4, edge_color="#999", ax=ax)
    nx.draw_networkx_nodes(G, pos,
        node_size=[200+degs[n]*150 for n in G.nodes()],
        node_color=list(degs.values()), cmap=plt.cm.RdYlGn, alpha=0.9, ax=ax)
    nx.draw_networkx_labels(G, pos, font_size=8, ax=ax)
    ax.set_title("Rede de Coocorrência de Termos (títulos + resumos)")
    ax.axis("off"); plt.tight_layout()
    path = savefig(os.path.join(out, "10_coocorrencia.png"))
    rows = [{"Termo_1":k[0],"Termo_2":k[1],"Coocorrências":v}
            for k,v in sorted(filtered.items(), key=lambda x:-x[1])]
    return path, pd.DataFrame(rows)

# ── 11. LDA ───────────────────────────────────────────────
def run_lda(df, out, n_topics=5):
    from sklearn.feature_extraction.text import CountVectorizer
    from sklearn.decomposition import LatentDirichletAllocation

    corpus = [" ".join(tokenize(r["title"]+" "+r.get("abstract","")+" "+r["keywords"]))
              for _, r in df.iterrows()]
    n_topics = max(2, min(n_topics, len(corpus)//2))

    vec = CountVectorizer(max_df=0.95, min_df=1, max_features=500)
    X   = vec.fit_transform(corpus)
    vocab = vec.get_feature_names_out()

    lda = LatentDirichletAllocation(n_components=n_topics, random_state=42, max_iter=20)
    lda.fit(X)
    doc_topics = lda.transform(X)

    rows = []
    fig, axes = plt.subplots(1, n_topics, figsize=(4*n_topics, 6))
    if n_topics == 1: axes = [axes]
    for idx, (topic, ax) in enumerate(zip(lda.components_, axes)):
        ti = topic.argsort()[-10:][::-1]
        tw = [vocab[i] for i in ti]; tv = [topic[i] for i in ti]
        ax.barh(tw[::-1], tv[::-1], color=plt.cm.tab10(idx/n_topics))
        ax.set_title(f"Tópico {idx+1}"); ax.set_xlabel("Peso")
        for w,v in zip(tw,tv): rows.append({"Tópico":idx+1,"Palavra":w,"Peso":round(v,4)})

    plt.suptitle("LDA — Palavras por Tópico", fontsize=14, fontweight="bold", y=1.02)
    plt.tight_layout()
    path = savefig(os.path.join(out, "11_lda_topicos.png"))

    doc_df = pd.DataFrame(doc_topics, columns=[f"T{i+1}" for i in range(n_topics)])
    doc_df.insert(0, "Título", df["title"].values)
    doc_df["Tópico_Dominante"] = doc_topics.argmax(axis=1)+1
    return path, pd.DataFrame(rows), doc_df, doc_topics, n_topics

# ── 12. BERTopic ──────────────────────────────────────────
def run_bertopic(df, out):
    """
    Executa BERTopic com modelo multilíngue leve.
    Se o corpus for muito pequeno (< 5 docs), aplica fallback para LDA.
    """
    from bertopic import BERTopic
    from sklearn.feature_extraction.text import CountVectorizer

    docs = [clean_text(r["title"]+" "+r.get("abstract","")+" "+r["keywords"])
            for _, r in df.iterrows()]
    docs = [d for d in docs if len(d.split()) >= 3]

    if len(docs) < 5:
        print("    (corpus pequeno demais para BERTopic — pulando)")
        return None, pd.DataFrame({"Nota":["Corpus insuficiente para BERTopic."]})

    try:
        from sentence_transformers import SentenceTransformer
        model_name = "paraphrase-multilingual-MiniLM-L12-v2"
        embedding_model = SentenceTransformer(model_name)
    except Exception as e:
        print(f"    Erro ao carregar SentenceTransformer: {e}")
        embedding_model = None

    cv = CountVectorizer(ngram_range=(1,2), stop_words=list(STOPWORDS))

    try:
        topic_model = BERTopic(
            embedding_model=embedding_model,
            vectorizer_model=cv,
            min_topic_size=max(2, len(docs)//5),
            verbose=False,
        )
        topics, _ = topic_model.fit_transform(docs)
    except Exception as e:
        print(f"    Erro BERTopic: {e}")
        return None, pd.DataFrame({"Nota":[f"Erro BERTopic: {e}"]})

    # Informações dos tópicos
    topic_info = topic_model.get_topic_info()
    # gráfico de barras dos top tópicos (excl. -1 = outliers)
    real_topics = topic_info[topic_info["Topic"] != -1].head(10)
    if real_topics.empty:
        return None, topic_info

    fig, ax = plt.subplots(figsize=(10, max(5, len(real_topics)*0.7)))
    ax.barh(real_topics["Name"].values[::-1],
            real_topics["Count"].values[::-1],
            color=plt.cm.Set3(np.linspace(0,1,len(real_topics))))
    ax.set(xlabel="Documentos no tópico",
           title="BERTopic — Tópicos Detectados\n(multilíngue)")
    plt.tight_layout()
    path = savefig(os.path.join(out, "12_bertopic.png"))

    # Tabela detalhada
    rows = []
    for _, trow in real_topics.iterrows():
        tid = trow["Topic"]
        words = topic_model.get_topic(tid)
        if words:
            top_words = ", ".join([w for w,_ in words[:10]])
        else:
            top_words = ""
        rows.append({"Tópico": tid, "Nome": trow["Name"],
                     "Documentos": trow["Count"], "Termos_chave": top_words})

    return path, pd.DataFrame(rows)

# ── 13. Tendências temáticas ──────────────────────────────
def plot_trends(df, out, doc_topics=None, n_topics=5):
    years = sorted(df["year_int"].unique())

    if doc_topics is not None:
        df2 = df.copy()
        df2["dom"] = doc_topics.argmax(axis=1)+1
        topic_by_yr = pd.DataFrame(index=years,
            columns=[f"T{i+1}" for i in range(n_topics)], dtype=float)
        for yr in years:
            mask = df2["year_int"] == yr
            for t in range(n_topics):
                topic_by_yr.at[yr,f"T{t+1}"] = doc_topics[mask.values,t].mean()

        fig, ax = plt.subplots(figsize=(13,6))
        for col in topic_by_yr.columns:
            ax.plot(years, topic_by_yr[col].values, marker="o", label=col, lw=2)
        ax.set(xlabel="Ano", ylabel="Proporção média", title="Tendências Temáticas (LDA)")
        ax.legend(title="Tópico"); ax.grid(alpha=0.3); plt.tight_layout()
        path = savefig(os.path.join(out, "13_tendencias_lda.png"))
        topic_by_yr.index.name = "Ano"
        return path, topic_by_yr.reset_index()

    # fallback: keywords por ano
    kw_c: Counter = Counter()
    for s in df["keywords"]:
        for kw in parse_keywords(s): kw_c[kw] += 1
    if not kw_c:
        for t in df["title"]:
            for tok in tokenize(t): kw_c[tok] += 1
    top10 = [t for t,_ in kw_c.most_common(10)]
    kw_by_yr: dict[int,Counter] = {}
    for yr in years:
        sub = df[df["year_int"]==yr]
        c: Counter = Counter()
        for s in sub["keywords"]:
            for kw in parse_keywords(s): c[kw] += 1
        if not c:
            for t in sub["title"]:
                for tok in tokenize(t): c[tok] += 1
        kw_by_yr[yr] = c

    fig, ax = plt.subplots(figsize=(14,7))
    for term in top10:
        ax.plot(years, [kw_by_yr.get(y,Counter()).get(term,0) for y in years],
                marker="o", label=term, lw=1.5)
    ax.set(xlabel="Ano", ylabel="Frequência", title="Tendências Temáticas (Top 10 termos)")
    ax.legend(bbox_to_anchor=(1.02,1), loc="upper left", fontsize=9)
    ax.grid(alpha=0.3); plt.tight_layout()
    path = savefig(os.path.join(out, "13_tendencias_keywords.png"))
    trend_df = pd.DataFrame({"Ano": years,
        **{t:[kw_by_yr.get(y,Counter()).get(t,0) for y in years] for t in top10}})
    return path, trend_df

# ── 14. Mapa colaboração ──────────────────────────────────
def plot_map(df, out):
    c: Counter = Counter()
    col = "openalex_country_code" if "openalex_country_code" in df.columns else "country"
    for s in df[col]:
        for part in re.split(r"[;,]", s):
            code = part.strip().upper()
            if len(code)==2: c[code] += 1
    if not c:
        return None, pd.DataFrame({"Nota":["Dados de países indisponíveis."]})

    country_df = pd.DataFrame(c.most_common(), columns=["iso_alpha2","count"])
    try:
        import plotly.express as px
        fig = px.choropleth(country_df, locations="iso_alpha2",
                            locationmode="ISO-3166-1-alpha-2", color="count",
                            color_continuous_scale="Blues",
                            title="Mapa de Colaboração Internacional",
                            labels={"count":"Publicações"})
        fig.write_html(os.path.join(out, "14_mapa_colaboracao.html"))
        print("    → Mapa interativo salvo como HTML")
    except Exception as e:
        print(f"    (plotly indisponível: {e})")
    return None, country_df


