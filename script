def _lookup_qualis(journal: str, issn: str = "") -> tuple:
    """Retorna (estrato, área) para um periódico."""
    # 1) por ISSN
    issn_clean = re.sub(r"[^0-9X]", "", (issn or "").upper())
    for i in range(0, len(issn_clean)-3, 4):
        key = issn_clean[:4] + "-" + issn_clean[4:8]
        if key in _QUALIS_DB:
            return _QUALIS_DB[key]

    # 2) por nome normalizado
    j_norm = journal.lower().strip()
    if j_norm in _JOURNAL_QUALIS:
        return _JOURNAL_QUALIS[j_norm]

    # 3) busca parcial
    for name, val in _JOURNAL_QUALIS.items():
        if name in j_norm or j_norm in name:
            return val

    return ("", "Não classificado")

def plot_qualis(df, out):
    """
    Analisa os periódicos por Qualis CAPES:
    - Distribuição de artigos por estrato (A1→C)
    - Ranking de periódicos com estrato
    - Gráfico de pizza por estrato
    """
    print("  → Análise Qualis CAPES")

    rows = []
    for _, row in df.iterrows():
        j    = str(row.get("journal","") or "").strip()
        issn = str(row.get("issn","") or row.get("number","") or "")
        estrato, area = _lookup_qualis(j, issn)
        rows.append({"Periódico": j, "Estrato": estrato,
                     "Área": area, "Ano": row.get("year_int","")})

    df_q = pd.DataFrame(rows)

    # ── Distribuição por estrato ──────────────────────────
    strata_count = df_q.groupby("Estrato").size().reset_index(name="Artigos")
    strata_count["Ordem"] = strata_count["Estrato"].map(
        lambda x: _QUALIS_ORDER.get(x, 10))
    strata_count = strata_count.sort_values("Ordem")

    STRATA_COLORS = {
        "A1":"#1a237e","A2":"#1565C0","A3":"#1E88E5","A4":"#64B5F6",
        "B1":"#2E7D32","B2":"#43A047","B3":"#A5D6A7","B4":"#C8E6C9",
        "C":"#F44336","":"#BDBDBD",
    }
    colors = [STRATA_COLORS.get(e,"#BDBDBD") for e in strata_count["Estrato"]]

    fig, axes = plt.subplots(1, 2, figsize=(14, 6))

    # barras
    ax = axes[0]
    bars = ax.bar(strata_count["Estrato"], strata_count["Artigos"],
                  color=colors, edgecolor="white")
    ax.set(xlabel="Estrato Qualis", ylabel="Artigos",
           title="Distribuição por Estrato Qualis CAPES")
    ax.bar_label(bars, padding=3)
    ax.grid(axis="y", alpha=0.3)

    # pizza
    ax2 = axes[1]
    classified = strata_count[strata_count["Estrato"] != ""]
    if not classified.empty:
        ax2.pie(classified["Artigos"], labels=classified["Estrato"],
                colors=[STRATA_COLORS.get(e,"#BDBDBD") for e in classified["Estrato"]],
                autopct="%1.1f%%", startangle=140, textprops={"fontsize":10})
        ax2.set_title("Proporção por Estrato\n(excl. não classificados)", fontsize=12)
    else:
        ax2.text(0.5, 0.5, "Sem dados classificados", ha="center", va="center")

    plt.tight_layout()
    path_dist = savefig(os.path.join(out, "14_qualis_distribuicao.png"))

    # ── Ranking periódicos com Qualis ─────────────────────
    journal_q = (df_q.groupby(["Periódico","Estrato","Área"])
                 .size().reset_index(name="Artigos")
                 .sort_values(["Ordem" if "Ordem" in df_q.columns else "Artigos"],
                              ascending=True))
    # add ordem para sort
    journal_q["Ordem"] = journal_q["Estrato"].map(lambda x: _QUALIS_ORDER.get(x,10))
    journal_q = journal_q.sort_values(["Ordem","Artigos"], ascending=[True,False])
    top30 = journal_q.head(30)

    if not top30.empty:
        bar_cols = [STRATA_COLORS.get(e,"#BDBDBD") for e in top30["Estrato"]]
        fig2, ax3 = plt.subplots(figsize=(12, max(6, len(top30)*0.45)))
        labels_j = [f'{r["Periódico"][:45]} [{r["Estrato"]}]'
                    for _, r in top30.iterrows()]
