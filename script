def clean_text(text):
    text = re.sub(r"\{[^{}]*\}", " ", text)
    text = re.sub(r"\\[a-zA-Z]+", " ", text)
    text = re.sub(r"[^\w\sáéíóúâêîôûãõàèìòùäëïöüçñ-]", " ", text, flags=re.UNICODE)
    return re.sub(r"\s+", " ", text).strip().lower()

def tokenize(text, min_len=3):
    return [w for w in clean_text(text).split()
            if len(w) >= min_len and w not in STOPWORDS]

def parse_authors(s):
    if not s: return []
    parts = re.split(r"\s+and\s+", s, flags=re.IGNORECASE)
    if len(parts) == 1:
        parts = [p.strip() for p in s.split(";") if p.strip()]
    return [p.strip() for p in parts if p.strip()]

def parse_keywords(s):
    if not s: return []
    sep = ";" if ";" in s else ","
    return [k.strip().lower() for k in s.split(sep) if k.strip()]

def _guess_country(text):
    t = text.lower()
    for alias, code in COUNTRY_ALIASES.items():
        if alias in t:
            return code
    return None


