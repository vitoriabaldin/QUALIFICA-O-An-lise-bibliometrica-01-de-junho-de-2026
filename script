        path_rank = None

    # evolução temporal por estrato
    df_q_yr = df_q[df_q["Estrato"] != ""].copy()
    if not df_q_yr.empty and "Ano" in df_q_yr.columns:
        pivot = (df_q_yr.groupby(["Ano","Estrato"])
                 .size().reset_index(name="n")
                 .pivot(index="Ano", columns="Estrato", values="n")
                 .fillna(0))
        ordered_cols = [c for c in ["A1","A2","A3","A4","B1","B2","B3","B4","C"]
