# ── Excel style helpers ───────────────────────────────────
HEADER_FILL   = PatternFill("solid", fgColor="1F4E79")
SUBHEAD_FILL  = PatternFill("solid", fgColor="2E75B6")
ALT_FILL      = PatternFill("solid", fgColor="D6E4F7")
HEADER_FONT   = Font(bold=True, color="FFFFFF", name="Arial", size=11)
BODY_FONT     = Font(name="Arial", size=10)
CENTER        = Alignment(horizontal="center", vertical="center", wrap_text=True)
LEFT          = Alignment(horizontal="left",   vertical="center", wrap_text=True)
THIN          = Side(style="thin", color="BFBFBF")
BORDER        = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)

def style_header(cell, fill=HEADER_FILL):
    cell.font      = HEADER_FONT
    cell.fill      = fill
    cell.alignment = CENTER
    cell.border    = BORDER

def style_body(cell, alt=False):
    cell.font      = BODY_FONT
    cell.fill      = ALT_FILL if alt else PatternFill("solid", fgColor="FFFFFF")
    cell.alignment = LEFT
    cell.border    = BORDER

def auto_width(ws, min_w=10, max_w=60):
    for col in ws.columns:
        best = min_w
        for cell in col:
            try:
                best = max(best, len(str(cell.value or "")))
            except Exception:
                pass
        ws.column_dimensions[get_column_letter(col[0].column)].width = min(best + 2, max_w)

def write_df_to_sheet(ws, df: pd.DataFrame, title: str = ""):
    """Write DataFrame to sheet with styled header."""
    if title:
        ws.append([title])
        ws.merge_cells(start_row=ws.max_row, start_column=1,
                       end_row=ws.max_row, end_column=len(df.columns))
        title_cell = ws.cell(ws.max_row, 1)
        title_cell.font      = Font(bold=True, name="Arial", size=13, color="1F4E79")
        title_cell.alignment = CENTER
        ws.row_dimensions[ws.max_row].height = 22
        ws.append([])  # blank row

    # Header
    ws.append(list(df.columns))
    for cell in ws[ws.max_row]:
        style_header(cell)
    ws.row_dimensions[ws.max_row].height = 18

    # Data rows
    for i, row in df.iterrows():
        ws.append(list(row))
        for cell in ws[ws.max_row]:
            style_body(cell, alt=(i % 2 == 1))
        ws.row_dimensions[ws.max_row].height = 15

    auto_width(ws)


