# Indicadores de que o título está em português
_PT_MARKERS = [
    "ção","ões","ção","ões","ão","ões","ão","ões",
    " do "," da "," de "," das "," dos "," em "," com "," para ",
    " por "," que "," não "," uma "," um "," os "," as ",
    "ismo","ista","ção","eiro","eira","mente",
]
_EN_MARKERS = [
    " the "," of "," and "," in "," for "," to "," a "," an ",
    " with "," on "," at "," by "," from "," or "," is "," are ",
]

def _detect_lang(title: str) -> str:
    """Retorna 'pt', 'en', ou 'und' (undetermined)."""
    t = " " + title.lower() + " "
    pt_hits = sum(1 for m in _PT_MARKERS if m in t)
    en_hits = sum(1 for m in _EN_MARKERS if m in t)
    if pt_hits >= 2 and pt_hits > en_hits:
        return "pt"
    if en_hits >= 3 and en_hits > pt_hits:
        return "en"
    return "und"

def filter_by_language(df: pd.DataFrame, keep_lang: str = "pt") -> tuple:
    """
    Retorna (df_kept, df_removed).
    Tenta campo 'language' do BibTeX primeiro; fallback para detecção por título.
    """
    lang_series = []
    for _, row in df.iterrows():
        lang_raw = str(row.get("language","") or "").strip().lower()
        if lang_raw in ("pt","por","português","portuguese"):
            lang_series.append("pt")
        elif lang_raw in ("en","eng","english","inglês"):
            lang_series.append("en")
        elif lang_raw in ("es","spa","español","espanhol","spanish"):
            lang_series.append("es")
        elif lang_raw:
            lang_series.append(lang_raw[:2])
        else:
            lang_series.append(_detect_lang(str(row.get("title","") or "")))

    df = df.copy()
    df["_lang_detected"] = lang_series
    mask = df["_lang_detected"].isin([keep_lang, "und"])
    df_kept    = df[mask].copy()
    df_removed = df[~mask].copy()
    return df_kept, df_removed

